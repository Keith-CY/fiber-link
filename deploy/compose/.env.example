# Required runtime values (set these before first bootstrap).
# POSTGRES_PASSWORD and FIBER_LINK_HMAC_SECRET must not stay default-like in shared envs.
# FNN_ASSET_SHA256 must match the selected FNN release asset digest exactly.
POSTGRES_DB=fiber_link
POSTGRES_USER=fiber
POSTGRES_PASSWORD=change-me-before-prod
POSTGRES_PORT=5432
POSTGRES_IMAGE=public.ecr.aws/docker/library/postgres:16-alpine

REDIS_IMAGE=public.ecr.aws/docker/library/redis:7-alpine
REDIS_PORT=6379
RPC_PORT=3000

# FNN_*_PORT / FNN2_*_PORT values only affect host publish ports in docker-compose.
# Internal FNN ports remain 8227/8228 per deploy/compose/fnn/config/testnet.yml.
FNN_VERSION=v0.6.1
FNN_ASSET=fnn_v0.6.1-x86_64-linux-portable.tar.gz
FNN_ASSET_SHA256=replace-with-release-sha256
# Run FNN as amd64 by default so the x86_64 Linux binary works on Apple Silicon hosts.
FNN_PLATFORM=linux/amd64
# Optional override; by default entrypoint binds RPC to container private IP (avoids public-listen auth requirement).
# FNN_RPC_LISTEN_ADDR=172.22.0.10:8227
FNN_RPC_PORT=8227
FNN_P2P_PORT=8228
FNN2_RPC_PORT=9227
FNN2_P2P_PORT=9228
FIBER_SECRET_KEY_PASSWORD=change-me-before-prod

# Compose-internal endpoint for Fiber Node RPC (used by rpc/worker containers).
FIBER_LINK_HMAC_SECRET=change-me-before-prod
FIBER_RPC_URL=http://fnn:8227
# Secondary Fiber RPC endpoint used by worker-side channel rotation peer acceptance.
FIBER_CHANNEL_ACCEPT_RPC_URL=http://fnn2:8227
# Optional settlement event stream endpoint; when unset worker keeps polling fallback.
FIBER_SETTLEMENT_SUBSCRIPTION_URL=
# testnet chain currency enum
FIBER_INVOICE_CURRENCY_CKB=Fibt
# Optional USDI override: keep aligned with CKB chain currency enum when set.
# FIBER_INVOICE_CURRENCY_USDI=Fibt
# Optional USDI xUDT selection override (JSON string or udt name):
# FIBER_USDI_UDT_NAME=RUSD
# FIBER_USDI_UDT_TYPE_SCRIPT_JSON={"code_hash":"0x...","hash_type":"type","args":"0x..."}
# Optional CKB on-chain withdrawal signer private key (32-byte hex with 0x prefix).
# FIBER_WITHDRAWAL_CKB_PRIVATE_KEY=0x...
RPC_HEALTHCHECK_TIMEOUT_MS=3000
BACKUP_RETENTION_DAYS=30
FIBER_LINK_RATE_LIMIT_REDIS_URL=redis://redis:6379/1
RPC_RATE_LIMIT_ENABLED=true
RPC_RATE_LIMIT_WINDOW_MS=60000
RPC_RATE_LIMIT_MAX_REQUESTS=300

# Withdrawal policy defaults (applies when per-app policy row is absent).
FIBER_WITHDRAWAL_POLICY_ALLOWED_ASSETS=CKB,USDI
FIBER_WITHDRAWAL_POLICY_MAX_PER_REQUEST=5000
FIBER_WITHDRAWAL_POLICY_PER_USER_DAILY_MAX=20000
FIBER_WITHDRAWAL_POLICY_PER_APP_DAILY_MAX=200000
FIBER_WITHDRAWAL_POLICY_COOLDOWN_SECONDS=0

WORKER_WITHDRAWAL_INTERVAL_MS=30000
WORKER_SETTLEMENT_INTERVAL_MS=30000
WORKER_SETTLEMENT_BATCH_SIZE=200
WORKER_MAX_RETRIES=3
WORKER_RETRY_DELAY_MS=60000
WORKER_SETTLEMENT_MAX_RETRIES=3
WORKER_SETTLEMENT_RETRY_DELAY_MS=60000
WORKER_SETTLEMENT_PENDING_TIMEOUT_MS=1800000
WORKER_SETTLEMENT_CURSOR_FILE=/var/lib/fiber-link/settlement-cursor.json
WORKER_SETTLEMENT_STRATEGY=subscription
WORKER_SHUTDOWN_TIMEOUT_MS=15000
WORKER_READINESS_TIMEOUT_MS=5000
WORKER_OPS_MAX_UNPAID_BACKLOG=25
WORKER_OPS_MAX_OLDEST_UNPAID_AGE_MS=900000
WORKER_OPS_MAX_RETRY_PENDING=3
WORKER_OPS_MAX_RECENT_FAILED_SETTLEMENTS=0
WORKER_OPS_RECENT_FAILURE_LOOKBACK_HOURS=24
WORKER_OPS_MAX_WITHDRAWAL_PARITY_ISSUES=0
WORKER_OPS_WITHDRAWAL_LOOKBACK_HOURS=24
WORKER_OPS_WITHDRAWAL_SAMPLE_LIMIT=500

# Liquidity fallback strategy for worker-side rebalance recovery.
# "none" keeps current behavior; "channel_rotation" enables replacement-channel fallback.
FIBER_LIQUIDITY_FALLBACK_MODE=channel_rotation
FIBER_CHANNEL_ROTATION_BOOTSTRAP_RESERVE=61
FIBER_CHANNEL_ROTATION_MIN_RECOVERABLE_AMOUNT=61
FIBER_CHANNEL_ROTATION_MAX_CONCURRENT=1
